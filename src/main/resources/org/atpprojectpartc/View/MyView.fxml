<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<BorderPane onMouseClicked="#mouseClicked" prefHeight="408.0" prefWidth="594.0" stylesheets="@MainStyle.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.atpprojectpartc.View.MyViewController">
    <left>
        <VBox fx:id="controlsVBox" prefHeight="200.0" prefWidth="178.0" spacing="5.0" BorderPane.alignment="CENTER" visible="false" managed="false">
            <children>
                <GridPane prefWidth="168.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <!-- NEW ROW FOR CHARACTER SELECTION -->
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <Label text="Maze rows:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <Label text="Maze columns:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <TextField fx:id="textField_mazeRows" text="50" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <TextField fx:id="textField_mazeColumns" text="50" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <!-- CHARACTER SELECTION - NEW ADDITION -->
                    <Label text="Character:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <ComboBox fx:id="characterComboBox" onAction="#setCharacter" prefWidth="100.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Sonic" />
                                <String fx:value="Knuckles" />
                                <String fx:value="Tails" />
                            </FXCollections>
                        </items>
                        <value>
                            <String fx:value="Sonic" />
                        </value>
                    </ComboBox>

                    <!-- UPDATED ROW INDICES (all moved down by 1) -->
                    <Button onAction="#generateMaze" prefHeight="25.0" prefWidth="167.0" text="Generate Maze" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="3" />
                    <Button cancelButton="true" onAction="#solveMaze" prefHeight="25.0" prefWidth="167.0" text="Solve Maze" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="4" />
                    <Label text="Player Row = " GridPane.rowIndex="5" />
                    <Label text="Player Col = " GridPane.rowIndex="6" />
                    <Label fx:id="playerRow" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                    <Label fx:id="playerCol" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                    <Label text="Goal Row = " GridPane.rowIndex="7" />
                    <Label text="Goal Col = " GridPane.rowIndex="8" />
                    <Label fx:id="goalRow" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                    <Label fx:id="goalCol" GridPane.columnIndex="1" GridPane.rowIndex="8" />
                </GridPane>
            </children>
            <padding>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
            </padding>
        </VBox>
    </left>
    <bottom>
        <HBox BorderPane.alignment="CENTER">
            <children>
                <Label text="Status bar" />
            </children>
        </HBox>
    </bottom>
    <top>
        <VBox BorderPane.alignment="CENTER">
            <children>
                <MenuBar>
                    <menus>
                        <Menu mnemonicParsing="false" text="File">
                            <items>
                                <MenuItem mnemonicParsing="false" onAction="#newMaze" text="New" />
                                <MenuItem mnemonicParsing="false" onAction="#saveFile" text="Save" />
                                <MenuItem mnemonicParsing="false" onAction="#loadFile" text="Load" />
                            </items>
                        </Menu>
                        <Menu mnemonicParsing="false" text="Options">
                            <items>
                                <MenuItem mnemonicParsing="false" onAction="#showPropertiesSummary" text="Properties Summary"/>
                            </items>
                        </Menu>
                        <Menu text="Exit">
                            <MenuItem text="Exit with Confirmation" onAction="#exitApplication"/>
                            <MenuItem text="Force Exit" onAction="#forceExit"/>
                        </Menu>
                        <Menu mnemonicParsing="false" text="Help">
                            <items>
                                <MenuItem mnemonicParsing="false" onAction="#showInstructions" text="Instructions" />
                                <MenuItem text="Controls Reference" onAction="#showControlsReference"/>
                                <MenuItem mnemonicParsing="false" onAction="#showAbout" text="About" />
                            </items>
                        </Menu>
                    </menus>
                </MenuBar>
            </children>
        </VBox>
    </top>
    <center>
        <ScrollPane fx:id="scrollPane" fitToHeight="false" fitToWidth="false" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED" BorderPane.alignment="CENTER">
            <content>
                <StackPane fx:id="mazeContainer">
                    <children>
                        <org.atpprojectpartc.MazeDisplayer fx:id="mazeDisplayer" imageFileNamePlayer="/org/atpprojectpartc/View/images/sonic.png" imageFileNameWall="/org/atpprojectpartc/View/images/wall.jpg" imageFileNameGoal="/org/atpprojectpartc/View/images/goal.png" imageFileNameSol="/org/atpprojectpartc/View/images/coin.png" onKeyPressed="#keyPressed" />
                    </children>
                </StackPane>
            </content>
            <padding>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
            </padding>
        </ScrollPane>
    </center>
</BorderPane>